# ============================================================================
# egyptian_hiero .gitignore
#
# Goal: keep all code, docs, configs, and small result/evidence artifacts;
# omit anything that's either (a) regenerable (venvs, tool caches, __pycache__)
# or (b) large binary data/weights that don't belong in git. See
# misc/PROJECT_NOTES.md and misc/RESETUP.md for how to regenerate everything
# excluded here.
# ============================================================================

# --- Virtual environments & managed toolchains (rebuild: bash misc/resetup.sh) ---
.venv/
**/.venv/
misc/.tools/

# --- Python / Jupyter cruft ---
__pycache__/
*.pyc
*.pyo
.ipynb_checkpoints/
*.egg-info/

# --- Leftover backup of the archaeohack-starterpack's original nested clone
# (kept on disk for provenance, not tracked; upstream: github.com/ArchaeoHack/archaeohack-starterpack)
hiero_data/archaeohack-starterpack/.git.orig-clone-backup/

# --- Raw / prepped datasets (multi-GB; see hiero_data/ and README provenance notes) ---
# Kept: small metadata siblings for the PRODUCTION dataset tier (hiero_*, hiero128_*
# -- content.pickle/corpus.txt/letters.txt/train.txt/test.txt/wid_map.json), same
# convention as pipelines/matching/runs/ below. Ignored: their image trees (large)
# and everything from disposable smoke-tier validation runs (hiero_smoke*, hs64*, hs128*).
hiero_data/Hand-drawn Hieroglyph Dataset/
One-DM/data/hiero/
One-DM/data/hiero128/
One-DM/data/hiero_smoke*
One-DM/data/hs64*
One-DM/data/hs128*

# --- Model weights & checkpoints (regenerate via download_weights.py / training runs) ---
One-DM/model_zoo/
One-DM/Saved/
*.pt
*.pth
*.ckpt
*.safetensors

# --- Misc training/output scratch dirs, if ever created ---
misc/outputs/
pipelines/matching/review/examples/*.png

# --- SLURM job logs & ephemeral job-id scratch notes (cluster/session-specific;
# the .sbatch scripts themselves and README/memory capture the reproducible part) ---
slurm/logs/
slurm/job_ids.env
slurm/best_gen.env

# --- External reference literature (public papers, not authored here) ---
misc/OneDM.pdf
hiero_data/archaeohack-starterpack/docs/*.pdf

# --- Dictionary app: large regenerable assets (rebuild: sbatch slurm/app_export.sbatch).
# Kept: app source, config.json (hand-tuned thresholds), index_meta/glyphs/selftest
# JSONs and export_report.json (small evidence, same convention as runs/). ---
app/data/model*.onnx
app/data/index.bin
app/glyphs/
app/vendor/
app/build/node_modules/
app/build/package-lock.json
